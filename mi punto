public class MiPunto {
    private double x;
    private double y;

    // Constructor sin argumentos
    public MiPunto() {
        this.x = 0;
        this.y = 0;
    }

    // Constructor con parámetros
    public MiPunto(double x, double y) {
        this.x = x;
        this.y = y;
    }

    // Métodos getter
    public double getX() {
        return x;
    }

    public double getY() {
        return y;
    }

    // Método distancia con objeto (polimorfismo)
    public double distancia(MiPunto p) {
        double dx = this.x - p.x;
        double dy = this.y - p.y;
        return Math.sqrt(dx * dx + dy * dy);
    }

    // Método distancia con coordenadas (sobrecarga)
    public double distancia(double x, double y) {
        double dx = this.x - x;
        double dy = this.y - y;
        return Math.sqrt(dx * dx + dy * dy);
    }
}
